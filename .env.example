# Copy to .env.local and fill in. Never commit real keys.

# --- Supabase ---
# From Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Do NOT expose to the browser. Used by the cron to write snapshots.
SUPABASE_SERVICE_ROLE_KEY=

# --- Market data ---
# Financial Modeling Prep (primary). Free tier: https://financialmodelingprep.com
FMP_API_KEY=
# Alpha Vantage (fallback). https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=

# --- Cron ---
# Shared secret checked by /api/cron/snapshot. Generate with `openssl rand -hex 32`.
CRON_SECRET=

# --- Email (Resend) ---
# Server-only. Used by /api/auth/email-link to deliver magic-link sign-in
# emails. If either is missing, the login form falls back to showing the
# link inline so the submitter can paste it into their browser.
# Get the key at https://resend.com/api-keys.
RESEND_API_KEY=
# Sender address. Must be on a domain you've verified in Resend, e.g.
#   RESEND_FROM="CIMG Portfolio <noreply@yourdomain.com>"
# For quick testing you can use the shared onboarding sender:
#   RESEND_FROM="CIMG Portfolio <onboarding@resend.dev>"
RESEND_FROM=
